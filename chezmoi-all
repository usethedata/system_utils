#!/usr/bin/env bash
# chezmoi-all — Run a chezmoi command on all chezmoi-managed hosts.
#
# Usage:
#   chezmoi-all [chezmoi-args...]
#   chezmoi-all                     # defaults to: chezmoi apply
#   chezmoi-all apply --dry-run --verbose
#   chezmoi-all diff
#   chezmoi-all status
#
# Reads the host list from config/chezmoi-hosts.json. If the current machine
# is in the list, chezmoi runs locally; all others run via SSH using the
# ssh_alias (which inherits User, Port, etc. from ~/.ssh/config).
#
# Unreachable hosts are logged as warnings; the script continues.
#
# Requires: BEWMAIN environment variable

set -euo pipefail

if [[ -z "${BEWMAIN:-}" ]]; then
    echo "Error: BEWMAIN environment variable is not set" >&2
    exit 1
fi

# Prefer a local copy of the host cache so launchd-triggered runs don't need
# Full Disk Access to read from ~/Library/CloudStorage/Dropbox/...
LOCAL_CACHE="${XDG_CONFIG_HOME:-$HOME/.config}/chezmoi-all/chezmoi-hosts.json"
CANONICAL_CACHE="${BEWMAIN}/Progs/Ongoing/Maintenance/utilities/config/chezmoi-hosts.json"
if [[ -f "$LOCAL_CACHE" ]]; then
    CACHE="$LOCAL_CACHE"
elif [[ -f "$CANONICAL_CACHE" ]]; then
    CACHE="$CANONICAL_CACHE"
else
    echo "Error: Host cache not found at $LOCAL_CACHE or $CANONICAL_CACHE" >&2
    echo "Run: make -C '${BEWMAIN}/Progs/Ongoing/Maintenance/utilities' all" >&2
    exit 1
fi

LOG_DIR="${BEWMAIN}/Data/logs"
LOG_FILE="${LOG_FILE:-${LOG_DIR}/chezmoi-all-$(date +%Y%m%d-%H%M%S).log}"
LOCAL_HOST="$(hostname -s)"
SSH_TIMEOUT=10

# Default to "apply" if no arguments given
if [[ $# -eq 0 ]]; then
    set -- apply
fi

mkdir -p "$LOG_DIR"

# When run interactively, duplicate output to the log file so the user
# sees it on the terminal AND it lands in the log. When run non-interactively
# (e.g. the chezmoi-all-dryrun launchd wrapper already does
# `exec >>"$LOG_FILE" 2>&1`), leave stdout/stderr alone — otherwise every
# line gets written to the log twice.
if [[ -t 1 ]]; then
    exec > >(tee -a "$LOG_FILE") 2>&1
fi

# Parse host list from JSON (simple grep/sed — no jq dependency needed)
aliases=()
while IFS= read -r line; do
    aliases+=("$line")
done < <(grep '"ssh_alias"' "$CACHE" | sed 's/.*"ssh_alias": *"//; s/".*//')

total=${#aliases[@]}
succeeded=0
failed=0
skipped=0

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

log "chezmoi-all: running 'chezmoi $*' on $total hosts"
log "Log file: $LOG_FILE"
echo ""

if (( total == 0 )); then
    log "ERROR: no hosts parsed from $CACHE — aborting"
    exit 1
fi

for alias in "${aliases[@]}"; do
    log "--- $alias ---"

    if [[ "$alias" == "$LOCAL_HOST" ]]; then
        # Run locally
        if chezmoi "$@" 2>&1; then
            log "$alias: OK (local)"
            succeeded=$((succeeded + 1))
        else
            log "WARNING: $alias: chezmoi exited with status $?"
            failed=$((failed + 1))
        fi
    else
        # Check reachability via SSH
        if ! ssh -o ConnectTimeout="$SSH_TIMEOUT" -o BatchMode=yes "$alias" true 2>/dev/null; then
            log "WARNING: $alias: unreachable (skipping)"
            skipped=$((skipped + 1))
            echo ""
            continue
        fi

        # Build a properly quoted remote command
        # Prepend common paths rather than sourcing profiles, which can have
        # side effects (e.g. Synology's .profile does exec zsh --login)
        remote_cmd='export PATH="$HOME/bin:$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"; chezmoi'
        for arg in "$@"; do
            remote_cmd+=" $(printf '%q' "$arg")"
        done

        if ssh -o ConnectTimeout="$SSH_TIMEOUT" "$alias" "$remote_cmd" 2>&1; then
            log "$alias: OK (remote)"
            succeeded=$((succeeded + 1))
        else
            log "WARNING: $alias: chezmoi exited with status $?"
            failed=$((failed + 1))
        fi
    fi
    echo ""
done

log "Summary: $succeeded succeeded, $failed failed, $skipped unreachable (of $total hosts)"
